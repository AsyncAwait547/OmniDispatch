# ─── OmniDispatch Environment Configuration ───
# Copy this file to `.env` and fill in your Azure credentials.
# The system works in MOCK mode without any credentials.

# ─── Azure OpenAI (for real LLM inference) ───
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ─── Azure AI Search (for RAG policy grounding) ───
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_KEY=your-search-key-here
AZURE_SEARCH_INDEX=omnidispatch-policies
